# Provider selector. Supported values:
# - local: local OpenAI-compatible server, usually Ollama
# - api: remote OpenAI-compatible API using API_KEY
MODEL_PROVIDER=local

# Local model settings.
# Default base URL in code: http://127.0.0.1:11434/v1
# Default model in code: hf.co/Qwen/Qwen3-14B-GGUF:Q4_K_M
LOCAL_MODEL_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_MODEL_NAME=hf.co/Qwen/Qwen3-14B-GGUF:Q4_K_M
LOCAL_API_KEY=ollama

# Remote API settings.
# Used only when MODEL_PROVIDER=api.
# Default base URL in code: https://api.openai.com/v1
# Default model in code: gpt-4o-mini
API_MODEL_BASE_URL=https://api.openai.com/v1
API_MODEL_NAME=gpt-4o-mini
API_KEY=your_api_key_here

# Shared generation parameters.
MODEL_TEMPERATURE=0.82
MODEL_TOP_P=0.92
MODEL_MAX_TOKENS=4096
MODEL_TIMEOUT_SECONDS=1200
MODEL_REPEAT_PENALTY=1.08

# Optional OpenAI-compatible parameters. Leave blank to omit.
MODEL_PRESENCE_PENALTY=
MODEL_FREQUENCY_PENALTY=
MODEL_SEED=
